# String Free - Environment Variables
# Copy this file to .env and fill in your values

# Supabase — Postgres database + auth
SUPABASE_URL=
SUPABASE_KEY=

# Google Gemini AI — used for task parsing and error summarization
GEMINI_API_KEY=

# Telegram Bot — primary user interface
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Sentry Error Tracking — optional, enables error learning loop
SENTRY_DSN=

# Lemon Squeezy Billing — webhook signature verification secret
LEMON_SQUEEZY_WEBHOOK_SECRET=

# Lemon Squeezy Plan Variant IDs — map product variants to plan tiers
LEMON_SQUEEZY_SOLO_VARIANT_ID=
LEMON_SQUEEZY_PRO_VARIANT_ID=
LEMON_SQUEEZY_TEAM_VARIANT_ID=

# Application
ENVIRONMENT=local
AI_DELAY_SECONDS=4

# Google Cloud Platform — Cloud Run deployment
GCP_PROJECT_ID=
GCP_REGION=me-central1
